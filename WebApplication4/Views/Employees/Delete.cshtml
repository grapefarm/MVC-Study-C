@model WebApplication4.Models.Employee

@{
    ViewData["Title"] = "Delete";
}

<h1>Delete</h1>

<h3>Are you sure you want to delete this?</h3>
<div>
    <h4>Employee</h4>
    <hr />
    <dl class="row">
        <dt class = "col-sm-2">
            @Html.DisplayNameFor(model => model.LastName)
        </dt>
        <dd class = "col-sm-10">
            @Html.DisplayFor(model => model.LastName)
        </dd>
        <dt class = "col-sm-2">
            @Html.DisplayNameFor(model => model.FirstName)
        </dt>
        <dd class = "col-sm-10">
            @Html.DisplayFor(model => model.FirstName)
        </dd>
        <dt class = "col-sm-2">
            @Html.DisplayNameFor(model => model.Title)
        </dt>
        <dd class = "col-sm-10">
            @Html.DisplayFor(model => model.Title)
        </dd>
    </dl>
    
    <form asp-action="Delete">
        <input type="hidden" asp-for="EmployeeId" id="targetId" />
        <input type="submit" value="Delete" class="btn btn-danger" /> |
        <button type="button" class="btn btn-success" id="btnSafeDelete">安全刪除</button>
        <a asp-action="Index">Back to List</a>
    </form>
</div>

@section Scripts {
    <script>
        const btnSafeDelete = document.querySelector('#btnSafeDelete');
        const employeeId = document.querySelector('#targetId').value;

        btnSafeDelete.addEventListener('click', async function () {
            const response = await fetch(`/Employees/CanDelete/${employeeId}`, {
                method: 'POST'
            });
            const result = await response.json();

            if (!result.canDelete) {
                alert(result.message);
                return;
            }
            if (confirm("確定要刪除這位員工嗎？")) {
                document.querySelector('form').submit();
            }
        });
    </script>
}
